# Subdirectories to descend into.
SUBDIRS = po
hello_SOURCES = src/hello.c src/system.h
hello_LDADD = lib/lib$(PACKAGE).a \
	$(HARD_LOCALE_LIB) \
	$(LIBC32CONV) \
	$(LIBICONV) \
	$(LIBINTL) \
	$(LIBUNISTRING) \
	$(MBRTOWC_LIB) \
	$(SETLOCALE_NULL_LIB)

CLEANFILES = $(am__append_2) lib/configmake.h lib/configmake.h-t
MAINTAINERCLEANFILES = lib/iconv_open-aix.h lib/iconv_open-hpux.h \
	lib/iconv_open-solaris.h lib/iconv_open-zos.h
@GIT_CROSS_COMPILING_FALSE@man_MANS = hello.1
TESTS = \
	tests/atexit-1 \
	tests/greeting-1 \
	tests/greeting-2 \
	tests/hello-1 \
	tests/last-1 \
	tests/operand-1 \
	tests/traditional-1

# No GNU Make output.
noinst_LIBRARIES = lib/libhello.a
MOSTLYCLEANFILES = lib/core lib/*.stackdump lib/alloca.h \
	lib/alloca.h-t lib/assert.h lib/assert.h-t lib/errno.h \
	lib/errno.h-t lib/error.h lib/error.h-t lib/fcntl.h \
	lib/fcntl.h-t lib/getopt.h lib/getopt.h-t lib/getopt-cdefs.h \
	lib/getopt-cdefs.h-t lib/iconv.h lib/iconv.h-t \
