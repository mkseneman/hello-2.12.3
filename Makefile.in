lib/libhello.a: $(lib_libhello_a_OBJECTS) $(lib_libhello_a_DEPENDENCIES) $(EXTRA_lib_libhello_a_DEPENDENCIES) lib/$(am__dirstamp)
	$(AM_V_at)-rm -f lib/libhello.a
	$(AM_V_AR)$(lib_libhello_a_AR) lib/libhello.a $(lib_libhello_a_OBJECTS) $(lib_libhello_a_LIBADD)
	$(AM_V_at)$(lib_libhello_a_RANLIB) lib/libhello.a
src/$(am__dirstamp):
	@$(MKDIR_P) src
	@: >>src/$(am__dirstamp)
src/$(DEPDIR)/$(am__dirstamp):
	@$(MKDIR_P) src/$(DEPDIR)
	@: >>src/$(DEPDIR)/$(am__dirstamp)
src/hello.$(OBJEXT): src/$(am__dirstamp) src/$(DEPDIR)/$(am__dirstamp)

hello$(EXEEXT): $(hello_OBJECTS) $(hello_DEPENDENCIES) $(EXTRA_hello_DEPENDENCIES) 
	@rm -f hello$(EXEEXT)
	$(AM_V_CCLD)$(LINK) $(hello_OBJECTS) $(hello_LDADD) $(LIBS)

mostlyclean-compile:
	-rm -f *.$(OBJEXT)
	-rm -f lib/*.$(OBJEXT)
	-rm -f lib/unicase/*.$(OBJEXT)
	-rm -f lib/unictype/*.$(OBJEXT)
	-rm -f lib/unistr/*.$(OBJEXT)
	-rm -f lib/uniwidth/*.$(OBJEXT)
	-rm -f src/*.$(OBJEXT)

distclean-compile:
	-rm -f *.tab.c

