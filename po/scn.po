#. TRANSLATORS: --help output 1 (synopsis)
#. no-wrap
#: src/hello.c:54
#, c-format
msgid "Usage: %s [OPTION]...\n"
msgstr "Usu: %s [UPZIONI]...\n"

#. TRANSLATORS: --help output 2 (brief description)
#. no-wrap
#: src/hello.c:57
msgid "Print a friendly, customizable greeting.\n"
msgstr "Stampa un salutu amichèvuli e pirsunalizzàbbili.\n"

#. TRANSLATORS: --help output 3: options
#. no-wrap
#: src/hello.c:61
msgid "  -t, --traditional       use traditional greeting\n"
msgstr "  -t, --traditional       usa u salutu tradizziunali\n"

#: src/hello.c:62
msgid "  -g, --greeting=TEXT     use TEXT as the greeting message\n"
msgstr "  -g, --greeting=TESTU     usa TESTU comu missaggiu pû salutu\n"

#: src/hello.c:65
msgid "      --help     display this help and exit\n"
msgstr "      --help     mustra st'ajutu e nesci\n"

#: src/hello.c:66
msgid "      --version  output version information and exit\n"
msgstr "      --version  mustra i nfurmazzioni ncapu â virsioni e nesci\n"

